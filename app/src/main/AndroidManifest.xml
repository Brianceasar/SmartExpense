<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <queries>
        <intent>
            <action android:name="android.intent.action.SENDTO" />
            <data android:scheme="mailto" />
        </intent>
    </queries>

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartExpense">

        <activity
            android:name="com.example.smartexpense.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.SmartExpense">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="com.example.smartexpense.MainActivity"
            android:exported="false"
            android:theme="@style/Theme.SmartExpense" />

        <activity
            android:name="com.example.smartexpense.HistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.SmartExpense" />

        <activity
            android:name="com.example.smartexpense.ProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.SmartExpense" />

    </application>

</manifest>
