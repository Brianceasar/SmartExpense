<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8FF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomNavigation"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <include layout="@layout/include_top_nav" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/dashboard_card_background"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_total_label"
                    android:textAllCaps="true"
                    android:textColor="#5C6472"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/totalSpentText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#50607A"
                    android:textSize="30sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/budgetProgress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="16dp"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/dashboard_progress_track" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/remainingBudgetText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="#5C6472"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/budgetUsedText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#00836C"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/dashboard_spending_overview"
                    android:textColor="#111C2D"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_last_days"
                    android:textColor="#5C6472"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="170dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/dashboard_chart_background"
                android:gravity="bottom"
                android:orientation="horizontal"
                android:padding="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    android:background="#48D8A8"
                    android:gravity="bottom|center_horizontal"
                    android:text="MON"
                    android:textColor="#D8E3FB"
                    android:textSize="8sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="62dp"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    android:background="#5DE0B6"
                    android:gravity="bottom|center_horizontal"
                    android:text="TUE"
                    android:textColor="#D8E3FB"
                    android:textSize="8sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="112dp"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    android:background="#84F3CE"
                    android:gravity="bottom|center_horizontal"
                    android:text="WED"
                    android:textColor="#D8E3FB"
                    android:textSize="8sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="124dp"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    android:background="#70E8BE"
                    android:gravity="bottom|center_horizontal"
                    android:text="THU"
                    android:textColor="#D8E3FB"
                    android:textSize="8sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="70dp"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    android:background="#4FD4A7"
                    android:gravity="bottom|center_horizontal"
                    android:text="FRI"
                    android:textColor="#D8E3FB"
                    android:textSize="8sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    android:background="#51DCAA"
                    android:gravity="bottom|center_horizontal"
                    android:text="SAT"
                    android:textColor="#D8E3FB"
                    android:textSize="8sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="118dp"
                    android:layout_marginHorizontal="4dp"
                    android:layout_weight="1"
                    android:background="#8DF5D2"
                    android:gravity="bottom|center_horizontal"
                    android:text="SUN"
                    android:textColor="#D8E3FB"
                    android:textSize="8sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/dashboard_recent_activity"
                    android:textColor="#111C2D"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/viewAllHistory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/dashboard_view_all"
                    android:textColor="#B80035"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/recentActivityList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@drawable/bottom_nav_background"
        app:itemActiveIndicatorStyle="@drawable/bottom_nav_active_indicator"
        app:itemIconTint="@color/bottom_nav_item_color"
        app:itemTextColor="@color/bottom_nav_item_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />
</RelativeLayout>
